{
  "name": "diagrammer",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "diagrammer": "./cli/diagrammer.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "VITE_E2E=true npm run build && playwright test",
    "diagrammer": "node cli/diagrammer.js",
    "ci": "npm run lint && npm run build && npm test && npm run test:e2e",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "serve": "^14.2.4",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "wrangler": "^4.95.0"
  }
}
