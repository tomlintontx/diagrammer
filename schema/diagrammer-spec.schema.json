{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diagrammer.dev/schema/diagrammer-spec.schema.json",
  "title": "Diagrammer Agent Spec",
  "description": "Agent-friendly diagram spec consumed by `diagrammer from-spec`.",
  "type": "object",
  "oneOf": [
    { "required": ["nodes"] },
    { "required": ["shapes"] }
  ],
  "properties": {
    "title": { "type": "string", "maxLength": 256 },
    "backgroundColor": { "type": "string", "maxLength": 64 },
    "viewport": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "zoom": { "type": "number", "minimum": 0.1, "maximum": 8 }
      },
      "additionalProperties": false
    },
    "styleDefaults": { "$ref": "diagrammer-v2.schema.json#/$defs/styleDefaults" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/edge" }
    },
    "shapes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": { "$ref": "diagrammer-v2.schema.json#/$defs/shape" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "x", "y"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "type": {
          "type": "string",
          "enum": ["rect", "ellipse", "diamond", "triangle", "text", "label"],
          "default": "rect"
        },
        "label": { "type": "string", "maxLength": 65536 },
        "text": { "type": "string", "maxLength": 65536 },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number", "minimum": 0, "maximum": 100000 },
        "h": { "type": "number", "minimum": 0, "maximum": 100000 },
        "style": { "$ref": "diagrammer-v2.schema.json#/$defs/styleFields" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "from": { "type": "string", "maxLength": 128 },
        "to": { "type": "string", "maxLength": 128 },
        "type": { "type": "string", "enum": ["arrow", "line"], "default": "arrow" },
        "label": { "type": "string", "maxLength": 65536 },
        "text": { "type": "string", "maxLength": 65536 },
        "fromSide": { "type": "string", "enum": ["top", "bottom", "left", "right"] },
        "toSide": { "type": "string", "enum": ["top", "bottom", "left", "right"] },
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" },
        "style": { "$ref": "diagrammer-v2.schema.json#/$defs/styleFields" }
      },
      "additionalProperties": false
    }
  }
}
